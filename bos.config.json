{
  "extends": "bos://dev.everything.near/dev.everything.dev",
  "account": "pay.everything.near",
  "domain": "pay.everything.dev",
  "title": "Payment Aggregator",
  "description": "A payment aggregator demo — one API for Stripe, PingPay, and NEAR staking. Use it in your own app.",
  "repository": "https://github.com/nearbuilders/payment-aggregator",
  "ci": {
    "railway": {
      "service": "app"
    }
  },
  "app": {
    "ui": {
      "development": "local:ui"
    },
    "api": {
      "development": "local:api",
      "secrets": [
        "API_DATABASE_URL"
      ]
    }
  },
  "plugins": {
    "pingpay": {
      "development": "local:plugins/pingpay",
      "secrets": [
        "PING_API_KEY",
        "PING_WEBHOOK_SECRET"
      ]
    },
    "stripe": {
      "development": "local:plugins/stripe",
      "secrets": [
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET"
      ]
    },
    "stake2pay": {
      "development": "local:plugins/stake2pay",
      "variables": {
        "rpcUrl": "https://test.rpc.fastnear.com",
        "networkId": "testnet",
        "contractId": "hos-e2e-0601144939.testnet",
        "productId": "prod_5lklj46roIwKZK"
      }
    }
  }
}
