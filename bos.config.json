{
  "extends": "bos://dev.everything.near/dev.everything.dev",
  "account": "pay.everything.near",
  "domain": "pay.everything.dev",
  "title": "everything.dev",
  "description": "Open runtime for apps on NEAR, composed from published config and loaded through a shared host, UI, and API runtime.",
  "staging": {
    "domain": "dev.everything.dev"
  },
  "repository": "https://github.com/nearbuilders/everything-dev",
  "ci": {
    "railway": {
      "service": "app"
    }
  },
  "app": {
    "ui": {
      "development": "local:ui"
    },
    "api": {
      "development": "local:api",
      "secrets": [
        "API_DATABASE_URL"
      ]
    }
  },
  "plugins": {
    "pingpay": {
      "development": "local:plugins/pingpay"
    },
    "stripe": {
      "development": "local:plugins/stripe"
    }
  }
}
