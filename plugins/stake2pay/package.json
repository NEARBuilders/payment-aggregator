{
  "name": "stake2pay",
  "version": "1.0.0",
  "description": "Stake2Pay subscription plugin (House of Stake NEAR staking) for every-plugin framework",
  "type": "module",
  "exports": {
    "./contract": {
      "types": "./src/contract.ts",
      "default": "./src/contract.ts"
    }
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@orpc/contract": "1.14.3",
    "@orpc/server": "1.14.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "every-plugin": "^2.7.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.8"
  },
  "scripts": {
    "build:types": "tsc -p tsconfig.contract.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  }
}
